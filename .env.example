# Environment variables for Bitcoin Tracker Docker deployment
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: .env contains secrets – do NOT commit it to version control!

# SQL Server SA password (min 8 chars, must contain uppercase, lowercase, digit, symbol)
MSSQL_SA_PASSWORD=YourStrong!Password

# Connection string for SQL Server (used by web container)
# Database will be created automatically on first startup
CONNECTION_STRING=Server=db;Database=BitcoinTracker;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True

# ASP.NET Core environment (Production for Docker, Development for local dev)
ASPNETCORE_ENVIRONMENT=Production
